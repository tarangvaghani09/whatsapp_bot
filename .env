# ── OpenAI (AI fallback) ──────────────────────────────────────────────────────
# Required only for the AI fallback feature. Get yours at https://platform.openai.com


AI_INTEGRATIONS_OPENAI_API_KEY=sk-YOUR_OPENAI_KEY
AI_INTEGRATIONS_OPENAI_BASE_URL=https://api.openai.com/v1

# ── WhatsApp Cloud API (optional — use Test Bot page to test without it) ──────
# Set these per-business in the admin UI (Businesses page) instead of here.
# These are only used as a global fallback if no business credentials are set.
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_VERIFY_TOKEN=my-local-verify-token

# AI_INTEGRATIONS_OPENAI_API_KEY

# WHATSAPP_APP_SECRET=... (for webhook signature verification)
# WHATSAPP_TOKEN_ENC_KEY=... (32-byte base64 key recommended)Optional dev-only:
# ALLOW_WHATSAPP_ENV_FALLBACK=true

# WHATSAPP_APP_SECRET
# Meta Developers -> Your App -> App Settings -> Basic -> App Secret.
# WHATSAPP_TOKEN_ENC_KEY
# This is your own key (not from Meta). Generate once and keep safe.
# PowerShell generate command:

# [Convert]::ToBase64String((1..32 | ForEach-Object {Get-Random -Minimum 0 -Maximum 256}))
# ALLOW_WHATSAPP_ENV_FALLBACK
# You choose manually (true only for local/dev).
# In production keep it unset or false.
