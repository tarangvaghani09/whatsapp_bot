# ── Database ─────────────────────────────────────────────────────────────────
# PostgreSQL connection string — replace with your local credentials
DATABASE_URL=postgresql://postgres:YOUR_PASSWORD@localhost:5432/whatsapp_bot
JWT_SECRET=change-this-to-a-long-random-string
APP_ORIGIN=http://localhost:5173
RESET_PASSWORD_TOKEN_TTL_MIN=15
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@example.com
SMTP_PASS=your_email_app_password
SMTP_FROM=WhatsApp Bot Admin <your_email@example.com>

# ── OpenAI (AI fallback) ──────────────────────────────────────────────────────
# Required only for the AI fallback feature. Get yours at https://platform.openai.com
AI_INTEGRATIONS_OPENAI_BASE_URL=https://api.openai.com/v1
AI_INTEGRATIONS_OPENAI_API_KEY=sk-YOUR_OPENAI_KEY

# ── WhatsApp Cloud API (optional — use Test Bot page to test without it) ──────
# Set these per-business in the admin UI (Businesses page) instead of here.
# These are only used as a global fallback if no business credentials are set.
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_VERIFY_TOKEN=my-local-verify-token
